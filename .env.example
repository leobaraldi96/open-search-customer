# Configuración de Base de Datos
# Formato: mysql+pymysql://usuario:password@host:puerto/nombre_bd
DATABASE_URL=mysql+pymysql://root:@localhost:3306/buscaclientes

# Claves de API de Google
# Consigue tu clave en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=TU_API_KEY_AQUI

# Clave para Google PageSpeed Insights (Opcional pero recomendada)
# Consigue la tuya en: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=TU_API_KEY_AQUI

# Opciones de Aplicación
PORT=8000
WORKER_PORT=8001
